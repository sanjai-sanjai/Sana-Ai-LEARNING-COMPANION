<?xml version="1.0" encoding="utf-8"?>
<!--
  Full-screen block overlay. Mirrors the visual language of
  src/components/app/StrictModeOverlay.tsx in the web project:
  purple gradient, glassmorphism, big time remaining, two actions.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0F0B1F">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_gradient_purple">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_shield"
            android:contentDescription="@string/strict_mode_icon_desc" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/overlay_title"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/blocked_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#DDFFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_return"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="@string/overlay_return"
            android:background="@drawable/bg_button_white" />

        <Button
            android:id="@+id/btn_emergency"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="@string/overlay_emergency"
            android:background="@drawable/bg_button_outline"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</FrameLayout>
